# ── Application ──────────────────────────────────────────────
APP_NAME=SupplyLink AI
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# ── Backend ────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=supplylink
POSTGRES_PASSWORD=supplylink_dev
POSTGRES_DB=supplylink
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://supplylink:supplylink_dev@postgres:5432/supplylink

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ── S3 / MinIO ────────────────────────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=supplylink
S3_REGION=us-east-1
S3_USE_SSL=false

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=SupplyLink AI

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── AI (Phase 4+) ────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
CHROMA_HOST=chroma
CHROMA_PORT=8001
